#!/bin/bash
set -e

echo "Resetuji test..."

# Smaž testuser
if id -u testuser >/dev/null 2>&1; then
    userdel -r testuser || true
fi

# Smaž skupinu project
if getent group project >/dev/null 2>&1; then
    groupdel project || true
fi

# Smaž pracovní složky
rm -rf /home/vivi/lab
rm -rf /home/vivi/extracted_lab
rm -rf /home/vivi/found
rm -rf /home/vivi/maze
rm -f /home/vivi/lab-archive.tar.xz
rm -f /home/vivi/grep_result.txt
rm -f /var/lib/lab-grader/t06_started /var/lib/lab-grader/t06_done
rm -f /var/lib/lab-grader/t12_shadow_before
rm -f /var/lib/lab-grader/state
rm -f /var/lib/lab-grader/seeded

# Zabij případný sleep proces
pkill -f "sleep 9999" || true

echo "Odinstalovávám mc..."
export DEBIAN_FRONTEND=noninteractive
apt-get purge -y mc || true
apt-get autoremove -y || true

echo "Spouštím nový seed..."
/opt/lab-grader/seed.sh

echo "Restartuji grader..."
systemctl restart lab-grader

echo "Restartuji tunel..."
systemctl restart rpi-vps-tunnel || true

echo "Hotovo. Restartuji Raspberry Pi za 3 sekundy..."
sleep 3
reboot
